{
    "_comment": "Copy to collector_config.local.json for local overrides.",
    "db": {
        "host":     "127.0.0.1",
        "port":     3306,
        "database": "bandwidth_monitor",
        "user":     "bm_user",
        "password": "change_me_now"
    },
    "poll_interval_seconds": 5,
    "ssh_defaults": {
        "port":             22,
        "timeout_seconds":  10,
        "key_path":         "/root/.ssh/id_ed25519",
        "known_hosts_policy": "auto_add"
    },
    "logging": {
        "level":    "INFO",
        "file":     "/var/log/bandwidth-collector.log",
        "max_bytes": 10485760,
        "backup_count": 5
    },
    "skip_interfaces_matching": [
        "^lo$",
        "^dummy",
        "^bond[0-9]+$",
        "^tun[0-9]*",
        "^tap[0-9]*",
        "^veth",
        "^docker",
        "^br-",
        "^virbr"
    ]
}
